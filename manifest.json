{
  "name": "Telegram Disappearing Photos (Web A)",
  "description": "Programmatically send self-destruct (disappearing) photos on web.telegram.org/a by instrumenting Telegram's MTProto worker.",
  "version": "2.0",
  "manifest_version": 3,
  "content_scripts": [
    {
      "matches": ["*://web.telegram.org/a*"],
      "js": ["disappearing.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "permissions": ["declarativeNetRequest"],
  "declarative_net_rules": {
    "rule_resources": [
      {
        "id": "csp",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "host_permissions": ["*://web.telegram.org/*"]
}
